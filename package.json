{
  "name": "avr-quickloader-v3",
  "version": "3.1.1",
  "description": "Professional AVR flashing and ISP utility",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "keywords": [
    "avr",
    "isp",
    "programmer",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/serialport": "^8.0.5",
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^1.8.0"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  },
  "build": {
    "appId": "com.kennyneutron.avr-quickloader",
    "productName": "AVR QuickLoader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "tools/**/*"
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
